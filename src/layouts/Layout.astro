---
import '../styles/global.css';
import StartupAnimation from '../components/StartupAnimation.astro';
import Clock from '../components/Clock.astro';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Baumkuchen', description = 'Baumkuchen 的个人博客' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: '首页', icon: '⌂' },
  { href: '/blog', label: '博客', icon: '✎' },
  { href: '/music', label: '音乐', icon: '♫' },
  { href: '/about', label: '关于', icon: '◎' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Baumkuchen</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body>
    <div class="scanlines" aria-hidden="true"></div>
    <StartupAnimation />
    <div class="page-layout">
      <nav class="sidebar" transition:persist>
        <a href="/about" class="sidebar-avatar-link" aria-label="关于">
          <div class="sidebar-avatar-ring">
            <img
              class="sidebar-avatar"
              src="https://avatars.githubusercontent.com/u/195563565?v=4"
              alt="Baumkuchen"
              width="40"
              height="40"
            />
          </div>
        </a>
        <div class="sidebar-nav">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={{
                'sidebar-item': true,
                active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)),
              }}
              title={item.label}
            >
              <span class="sidebar-icon">{item.icon}</span>
              <span class="sidebar-label">{item.label}</span>
              <span class="sidebar-indicator"></span>
            </a>
          ))}
        </div>
      </nav>
      <main class="main-content">
        <div class="content-area">
          <slot />
        </div>
      </main>
    </div>
    <Clock />
    <footer class="footer">
      <p>&copy; {new Date().getFullYear()} Baumkuchen. 保留所有权利。</p>
    </footer>

    <div class="global-player" id="global-player" transition:persist>
      <audio id="global-audio" preload="metadata"></audio>
      <button class="gp-play" id="gp-play">▸</button>
      <button class="gp-mode" id="gp-mode" title="列表循环">↻</button>
      <div class="gp-info">
        <div class="gp-name" id="gp-name"></div>
        <div class="gp-track" id="gp-track">
          <div class="gp-progress" id="gp-progress"></div>
        </div>
      </div>
      <span class="gp-time" id="gp-time">0:00</span>
    </div>

    <div class="lyrics-card" id="lyrics-card" transition:persist>
      <div class="lyrics-header">
        <span class="lyrics-title" id="lyrics-title"></span>
        <button class="lyrics-close" id="lyrics-close" title="关闭歌词">✕</button>
      </div>
      <div class="lyrics-body" id="lyrics-body"></div>
    </div>

    <script>
      (() => {
        // Guard: only initialize once (View Transitions may re-run scripts)
        if (window.__gp_init) return;
        window.__gp_init = true;

        var audio = document.getElementById('global-audio');
        var player = document.getElementById('global-player');
        var playBtn = document.getElementById('gp-play');
        var modeBtn = document.getElementById('gp-mode');
        var nameEl = document.getElementById('gp-name');
        var track = document.getElementById('gp-track');
        var progress = document.getElementById('gp-progress');
        var timeEl = document.getElementById('gp-time');

        // Play mode: 'list' | 'single' | 'shuffle'
        var MODES = ['list', 'single', 'shuffle'];
        var MODE_ICONS = { list: '↻', single: '↺', shuffle: '↯' };
        var MODE_TITLES = { list: '列表循环', single: '单曲循环', shuffle: '随机播放' };

        var playMode = 'list';
        var savedMode = sessionStorage.getItem('gp-mode');
        if (savedMode && MODES.indexOf(savedMode) !== -1) playMode = savedMode;
        modeBtn.textContent = MODE_ICONS[playMode];
        modeBtn.title = MODE_TITLES[playMode];

        function fmt(sec) {
          sec = Math.floor(sec || 0);
          return Math.floor(sec / 60) + ':' + (sec % 60 < 10 ? '0' : '') + (sec % 60);
        }

        // Restore session — show player but don't auto-play (browser policy)
        var saved = sessionStorage.getItem('gp');
        if (saved) {
          try {
            var state = JSON.parse(saved);
            if (state.name) {
              player.classList.add('active');
              nameEl.textContent = state.name;
              audio.src = state.url;
              if (state.time) audio.currentTime = state.time;
              // Don't auto-play — user must click to resume after navigation
              playBtn.textContent = state.playing ? '▸' : '▸';
            }
          } catch(e) {}
        }

        // Save state periodically
        function saveState() {
          sessionStorage.setItem('gp', JSON.stringify({
            name: nameEl.textContent,
            url: audio.src,
            time: audio.currentTime,
            playing: !audio.paused
          }));
        }

        window.addEventListener('beforeunload', function() { saveState(); });

        // ── Play / Pause ──
        playBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          if (audio.paused) { audio.play().catch(function(){}); playBtn.textContent = '❚❚'; }
          else { audio.pause(); playBtn.textContent = '▸'; }
        });

        audio.addEventListener('timeupdate', function() {
          if (audio.duration) {
            progress.style.width = (audio.currentTime / audio.duration) * 100 + '%';
            timeEl.textContent = fmt(audio.currentTime);
            saveState();
          }
        });

        audio.addEventListener('loadedmetadata', function() {
          progress.style.width = '0%';
        });

        function playSongFromPlaylist(song) {
          var url = 'https://music.163.com/song/media/outer/url?id=' + song.id + '.mp3';
          audio.src = url;
          nameEl.textContent = song.name;
          player.classList.add('active');
          playBtn.textContent = '❚❚';
          progress.style.width = '0%';
          timeEl.textContent = '0:00';
          audio.play().catch(function(){});
          saveState();
        }

        audio.addEventListener('ended', function() {
          if (playMode === 'single') {
            audio.currentTime = 0;
            audio.play().catch(function(){});
            return;
          }

          var list = [];
          try {
            var raw = sessionStorage.getItem('gp-playlist');
            if (raw) list = JSON.parse(raw);
          } catch(e) {}

          if (!list.length) {
            playBtn.textContent = '▸';
            progress.style.width = '0%';
            timeEl.textContent = '0:00';
            return;
          }

          if (playMode === 'shuffle') {
            var idx = Math.floor(Math.random() * list.length);
            playSongFromPlaylist(list[idx]);
          } else {
            // list loop
            var currentId = '';
            var m = audio.src.match(/[?&]id=(\d+)/);
            if (m) currentId = m[1];
            var curIdx = -1;
            for (var i = 0; i < list.length; i++) {
              if (String(list[i].id) === currentId) { curIdx = i; break; }
            }
            var nextIdx = curIdx >= 0 ? (curIdx + 1) % list.length : 0;
            playSongFromPlaylist(list[nextIdx]);
          }
        });

        track.addEventListener('click', function(e) {
          var rect = track.getBoundingClientRect();
          var pct = (e.clientX - rect.left) / rect.width;
          if (audio.duration) audio.currentTime = pct * audio.duration;
        });

        // ── Play mode toggle ──
        modeBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          var cur = MODES.indexOf(playMode);
          playMode = MODES[(cur + 1) % MODES.length];
          modeBtn.textContent = MODE_ICONS[playMode];
          modeBtn.title = MODE_TITLES[playMode];
          sessionStorage.setItem('gp-mode', playMode);
        });

        // ── Lyrics ──
        var lrcCard, lrcTitle, lrcBody, lrcLines = [], lrcActiveIdx = -1, lrcLastSongId;
        var _syncRaf;

        function showLyrics(name) {
          lrcCard = lrcCard || document.getElementById('lyrics-card');
          lrcTitle = lrcTitle || document.getElementById('lyrics-title');
          lrcTitle.textContent = name;
          lrcCard.classList.add('visible');
        }
        function hideLyrics() {
          lrcCard = lrcCard || document.getElementById('lyrics-card');
          lrcCard.classList.remove('visible');
          lrcLines = [];
          lrcActiveIdx = -1;
        }
        document.getElementById('lyrics-close').addEventListener('click', hideLyrics);

        function parseLrc(raw) {
          var lines = raw.split('\n');
          var out = [];
          var tagRe = /^\[(\d+):(\d+(?:[.,]\d+)?)\](.*)/;
          var metaRe = /^(作词|作曲|编曲|制作人|混音|母带|录音|和声|吉他|贝斯|键盘|钢琴|鼓|弦乐|歌词|Lyrics|Composer|Arranger|Producer|Mix|Master)[\s:：]/i;
          for (var i = 0; i < lines.length; i++) {
            var m = lines[i].match(tagRe);
            if (!m) continue;
            var mins = parseInt(m[1], 10);
            var secs = parseFloat(m[2].replace(',', '.'));
            var text = m[3].trim();
            if (!text) continue;
            if (metaRe.test(text)) continue;
            out.push({ time: mins * 60 + secs, text: text });
          }
          out.sort(function(a, b) { return a.time - b.time; });
          return out;
        }

        function buildLrcHtml(parsed, cls) {
          var html = '';
          for (var i = 0; i < parsed.length; i++) {
            html += '<p class="lrc-line ' + (cls || '') + '" data-time="' + parsed[i].time + '">' + parsed[i].text + '</p>';
          }
          return html;
        }

        function syncLyrics() {
          if (_syncRaf) return;
          _syncRaf = requestAnimationFrame(function() {
            _syncRaf = null;
            if (!lrcLines.length) return;
            if (!audio.duration) return;
            var t = audio.currentTime || 0;
            var idx = -1;
            for (var i = 0; i < lrcLines.length; i++) {
              var lineTime = parseFloat(lrcLines[i].getAttribute('data-time'));
              if (isNaN(lineTime)) continue;
              if (lineTime <= t) idx = i;
              else break;
            }
            if (idx === lrcActiveIdx) return;
            for (var j = 0; j < lrcLines.length; j++) {
              lrcLines[j].style.display = 'none';
              lrcLines[j].classList.remove('prev', 'next');
            }
            if (lrcActiveIdx >= 0 && lrcActiveIdx < lrcLines.length) {
              lrcLines[lrcActiveIdx].classList.remove('active');
            }
            if (idx >= 0) {
              lrcLines[idx].style.display = '';
              lrcLines[idx].classList.add('active');
              if (idx > 0) { lrcLines[idx - 1].style.display = ''; lrcLines[idx - 1].classList.add('prev'); }
              if (idx < lrcLines.length - 1) { lrcLines[idx + 1].style.display = ''; lrcLines[idx + 1].classList.add('next'); }
              lrcLines[idx].scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            lrcActiveIdx = idx;
          });
        }

        function fetchLyrics(id, name) {
          if (id === lrcLastSongId) return;
          lrcLastSongId = id;
          hideLyrics();
          audio.removeEventListener('timeupdate', syncLyrics);
          audio.removeEventListener('seeked', syncLyrics);

          var url = '/api/music/lyric?os=pc&id=' + id + '&lv=-1&kv=-1&tv=-1';
          fetch(url)
            .then(function(r) { return r.json(); })
            .then(function(d) {
              if (d.code !== 200) { hideLyrics(); return; }
              if (d.pureMusic) { hideLyrics(); return; }

              var lrc = (d.lrc && d.lrc.lyric) || '';
              var tlrc = (d.tlyric && d.tlyric.lyric) || '';
              var cleaned = lrc.replace(/纯音乐[，,]?\s*请欣赏/i, '').trim();
              if (cleaned === lrc) cleaned = lrc.trim();

              var parsed = cleaned ? parseLrc(cleaned) : [];
              var tParsed = tlrc ? parseLrc(tlrc) : [];
              if (!parsed.length && !tParsed.length) { hideLyrics(); return; }

              var html = buildLrcHtml(parsed, 'lrc-orig');
              if (tParsed.length) {
                html += '<hr class="lyrics-divider">' + buildLrcHtml(tParsed, 'lrc-trans');
              }

              lrcBody = lrcBody || document.getElementById('lyrics-body');
              lrcBody.innerHTML = html;
              lrcActiveIdx = -1;
              showLyrics(name);

              lrcLines = Array.from(lrcBody.querySelectorAll('.lrc-line'));
              audio.addEventListener('timeupdate', syncLyrics);
              audio.addEventListener('seeked', syncLyrics);
              syncLyrics();
            })
            .catch(function() { hideLyrics(); });
        }

        // Watch for new song playback
        var _lastPlaySrc;
        audio.addEventListener('play', function() {
          var src = audio.src;
          if (!src || src === _lastPlaySrc) return;
          _lastPlaySrc = src;
          var m = src.match(/[?&]id=(\d+)/);
          if (m) fetchLyrics(m[1], nameEl.textContent);
        });

        // Restore lyrics card visibility after ClientRouter navigations
        document.addEventListener('astro:after-swap', function() {
          var body = document.getElementById('lyrics-body');
          var card = document.getElementById('lyrics-card');
          if (body && body.children.length > 0 && card) {
            card.classList.add('visible');
          }
        });
      })();
    </script>
    <script>
      // Keep sidebar active state in sync across ClientRouter navigations
      (function() {
        function update() {
          var path = window.location.pathname;
          document.querySelectorAll('.sidebar-item').forEach(function(el) {
            var href = el.getAttribute('href');
            el.classList.toggle('active', path === href || (href !== '/' && path.startsWith(href)));
          });
        }
        update();
        document.addEventListener('astro:after-swap', update);
      })();
    </script>
  </body>
</html>

<style is:global>
  .page-layout {
    display: flex;
    min-height: 100vh;
  }

  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 72px;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 0;
    background: rgba(10, 10, 20, 0.85);
    border-right: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 100;
    gap: 0.5rem;
  }

  .sidebar-avatar-link {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    text-decoration: none !important;
    position: relative;
  }

  .sidebar-avatar-ring {
    position: relative;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar-avatar-ring::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-cyan), var(--accent-secondary));
    opacity: 0.5;
    animation: ring-spin 3s linear infinite;
  }

  @keyframes ring-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .sidebar-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(10, 10, 20, 0.9);
    position: relative;
    z-index: 1;
    transition: box-shadow 0.2s;
  }

  .sidebar-avatar-link:hover .sidebar-avatar {
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 100%;
    padding: 0 0.5rem;
    position: relative;
  }

  .sidebar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 0.6rem 0;
    border-radius: 8px;
    text-decoration: none !important;
    color: var(--text-dim) !important;
    transition: all 0.2s;
    cursor: pointer;
    position: relative;
  }

  .sidebar-item:hover {
    background: var(--bg-hover);
    color: var(--text-bright) !important;
  }

  .sidebar-item.active {
    background: var(--bg-hover);
    color: var(--accent) !important;
  }

  .sidebar-indicator {
    position: absolute;
    left: -6px;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 0;
    border-radius: 0 2px 2px 0;
    background: linear-gradient(180deg, var(--accent), var(--accent-cyan));
    transition: height 0.2s;
  }

  .sidebar-item.active .sidebar-indicator,
  .sidebar-item:hover .sidebar-indicator {
    height: 20px;
  }

  .sidebar-icon {
    font-size: 1.5rem;
    line-height: 1;
    position: relative;
  }

  .sidebar-icon::after {
    display: none;
  }

  .sidebar-item.active .sidebar-icon::after {
    display: block;
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 4px;
    background: var(--accent-glow);
    filter: blur(8px);
    z-index: -1;
  }

  .sidebar-label {
    font-size: 0.65rem;
    line-height: 1;
  }

  .main-content {
    flex: 1;
    margin-left: 96px;
    min-height: 100vh;
    padding: 0 1.5rem;
  }

  .content-area {
    max-width: 720px;
    margin: 0 auto;
  }

  .footer {
    margin-top: 5rem;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--border);
    margin-left: 96px;
    display: flex;
    justify-content: center;
    color: var(--text-dim);
    font-size: 0.85rem;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
    position: relative;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-glow), transparent);
  }

  @media (max-width: 768px) {
    .sidebar {
      top: auto;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 64px;
      flex-direction: row;
      justify-content: center;
      padding: 0.4rem 0.75rem;
      gap: 0;
      border-right: none;
      border-top: 1px solid var(--border);
      background: rgba(10, 10, 20, 0.92);
      backdrop-filter: blur(16px);
      z-index: 200;
    }

    .sidebar-avatar-link {
      margin-bottom: 0;
      width: 36px;
      height: 36px;
      flex-shrink: 0;
      margin-right: 0.25rem;
    }

    .sidebar-avatar-ring {
      width: 32px;
      height: 32px;
    }

    .sidebar-avatar-ring::before {
      inset: -1px;
    }

    .sidebar-avatar {
      width: 28px;
      height: 28px;
    }

    .sidebar-nav {
      flex-direction: row;
      flex: 1;
      padding: 0;
      justify-content: space-around;
      gap: 0;
      width: auto;
    }

    .sidebar-item {
      flex-direction: column;
      gap: 1px;
      padding: 0.35rem 0.4rem;
      border-radius: 6px;
      flex: 1;
      max-width: 64px;
    }

    .sidebar-indicator {
      left: 50%;
      top: -4px;
      transform: translateX(-50%);
      width: 0;
      height: 0;
      border-radius: 0 0 2px 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent-cyan));
    }

    .sidebar-item.active .sidebar-indicator,
    .sidebar-item:hover .sidebar-indicator {
      width: 20px;
      height: 3px;
    }

    .sidebar-icon {
      font-size: 1.25rem;
    }

    .sidebar-item.active .sidebar-icon::after {
      filter: blur(6px);
      inset: -2px;
    }

    .sidebar-label {
      display: block;
      font-size: 0.6rem;
    }

    .main-content {
      margin-left: 0;
      padding: 0 1rem 80px 1rem;
    }

    .footer {
      margin-left: 0;
      padding-bottom: calc(2rem + 72px);
    }
  }

  @media (max-width: 600px) {
    .sidebar {
      height: 60px;
      padding: 0.35rem 0.5rem;
    }

    .sidebar-item {
      max-width: 56px;
      padding: 0.3rem 0.3rem;
    }

    .sidebar-icon {
      font-size: 1.15rem;
    }

    .sidebar-label {
      font-size: 0.55rem;
    }

    .main-content {
      padding: 0 0.75rem 76px 0.75rem;
    }

    .footer {
      padding-bottom: calc(2rem + 68px);
    }
  }

  @media (max-width: 400px) {
    .sidebar {
      height: 56px;
      padding: 0.25rem 0.25rem;
    }

    .sidebar-avatar-link {
      width: 32px;
      height: 32px;
      margin-right: 0;
    }

    .sidebar-avatar-ring {
      width: 28px;
      height: 28px;
    }

    .sidebar-avatar {
      width: 24px;
      height: 24px;
    }

    .sidebar-nav {
      gap: 0;
    }

    .sidebar-item {
      padding: 0.25rem 0.2rem;
      max-width: 52px;
    }

    .sidebar-icon {
      font-size: 1rem;
    }

    .sidebar-label {
      font-size: 0.5rem;
    }

    .main-content {
      padding: 0 0.5rem 72px 0.5rem;
    }

    .footer {
      padding-bottom: calc(2rem + 64px);
    }
  }

  /* ── Global pill player ── */
  .global-player {
    display: none;
    position: fixed;
    left: 84px;
    bottom: 20px;
    z-index: 200;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem 0.4rem 0.5rem;
    background: rgba(8, 8, 16, 0.88);
    border: 1px solid var(--border);
    border-radius: 100px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    min-width: 180px;
    max-width: 320px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
  }
  .global-player.active { display: flex; }

  .gp-play {
    width: 28px; height: 28px; flex-shrink: 0; border-radius: 50%;
    border: 1px solid var(--accent); background: transparent; color: var(--accent);
    font-size: 0.65rem; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
  }
  .gp-play:hover { background: rgba(108, 99, 255, 0.15); box-shadow: 0 0 12px var(--accent-glow); }

  .gp-mode {
    width: 24px; height: 24px; flex-shrink: 0; border-radius: 50%;
