---
import Layout from '../../layouts/Layout.astro';
import { parsePostsFromModules } from '../../lib/utils/posts';

const mdModules = import.meta.glob('/src/posts/*.md', {
	eager: true,
	query: '?raw',
	import: 'default'
}) as Record<string, string>;

const allModules = parsePostsFromModules(mdModules);
const allPosts = allModules
	.filter((p) => p.type === 'post')
	.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout currentPath="/posts">
	<div class="home-container" id="posts-container" data-posts={JSON.stringify(allPosts.map(p => ({
		title: p.title,
		date: p.date,
		updated: p.updated,
		category: p.category,
		slug: p.slug,
		banner: p.banner
	})))}>
		<h1>所有文章</h1>

		<mdui-text-field
			class="search-bar"
			variant="outlined"
			placeholder="搜索标题、日期、分类…"
			icon="search"
			id="search-field"
		></mdui-text-field>

		<div class="post-grid" id="post-grid"></div>

		<div class="pagination" id="pagination"></div>
	</div>
</Layout>

<script>
	import { navigate } from 'astro:transitions/client';

	function prefetchPage(url) {
		const link = document.createElement('link');
		link.rel = 'prefetch';
		link.href = url;
		document.head.appendChild(link);
	}

	const pageSize = 5;
	let searchQuery = '';
	let currentPage = 1;
	let postsData = [];

	function filteredPosts() {
		if (!searchQuery) return postsData;
		const q = searchQuery.toLowerCase();
		return postsData.filter((p) =>
			p.title.toLowerCase().includes(q) ||
			p.date.includes(q) ||
			(p.updated || '').includes(q) ||
			(p.category || '').toLowerCase().includes(q)
		);
	}

	function renderPosts() {
		const grid = document.getElementById('post-grid');
		const pagination = document.getElementById('pagination');
		if (!grid) return;

		const filtered = filteredPosts();
		const totalPages = Math.ceil(filtered.length / pageSize) || 1;
		const paginated = filtered.slice((currentPage - 1) * pageSize, currentPage * pageSize);

		grid.innerHTML = '';

		if (paginated.length === 0) {
			grid.innerHTML = '<p class="no-results">没有找到匹配的文章</p>';
		} else {
			paginated.forEach((post) => {
				const cardWrap = document.createElement('div');
				cardWrap.className = 'post-card-wrap';

				const cardEl = document.createElement('mdui-card');
				cardEl.variant = 'outlined';
				cardEl.className = 'post-card';
				cardEl.style.cssText = 'width:100%;display:block;transition:transform 0.2s,border-color 0.2s';
				cardWrap.addEventListener('mouseenter', () => {
					cardEl.style.transform = 'translateX(8px)';
					cardEl.style.borderColor = 'var(--accent)';
				});
				cardWrap.addEventListener('mouseleave', () => {
					cardEl.style.transform = '';
					cardEl.style.borderColor = '';
				});

				let html = '';
				if (post.banner) {
					html += `<div class="card-banner" style="width:100%;height:160px;overflow:hidden;border-radius:12px 12px 0 0">
						<img src="${post.banner}" alt="${post.title}" style="width:100%;height:100%;object-fit:cover;display:block" />
					</div>`;
				}
				html += `<div class="card-content" style="padding:20px">
					<h2 style="margin:0 0 8px">${post.title}</h2>
					<p class="date" style="color:var(--text-secondary);font-size:0.9em;margin:0">${post.date}</p>`;
				if (post.category) {
					html += `<mdui-chip variant="flat" class="card-category" style="margin-top:8px">${post.category}</mdui-chip>`;
				}
				html += `<p class="excerpt" style="margin:8px 0 0;color:var(--text-secondary)">点击查看详情...</p></div>`;

				cardEl.innerHTML = html;
				const slug = post.slug;
				cardWrap.addEventListener('mouseenter', () => prefetchPage(`/posts/${slug}`), { once: true });
				cardWrap.addEventListener('click', () => {
					navigate(`/posts/${slug}`);
				});
				cardWrap.appendChild(cardEl);
				grid.appendChild(cardWrap);
			});
		}

		renderPagination(totalPages);
	}

	function renderPagination(totalPages) {
		const pagination = document.getElementById('pagination');
		if (!pagination) return;

		pagination.innerHTML = '';
		if (totalPages <= 1) return;

		const prevBtn = document.createElement('mdui-button');
		prevBtn.variant = 'text';
		prevBtn.disabled = currentPage === 1;
		prevBtn.textContent = '上一页';
		prevBtn.addEventListener('click', () => {
			if (currentPage > 1) { currentPage--; renderPosts(); }
		});

		const pageInfo = document.createElement('span');
		pageInfo.textContent = `第 ${currentPage} / ${totalPages} 页`;

		const nextBtn = document.createElement('mdui-button');
		nextBtn.variant = 'text';
		nextBtn.disabled = currentPage === totalPages;
		nextBtn.textContent = '下一页';
		nextBtn.addEventListener('click', () => {
			if (currentPage < totalPages) { currentPage++; renderPosts(); }
		});

		pagination.appendChild(prevBtn);
		pagination.appendChild(pageInfo);
		pagination.appendChild(nextBtn);
	}

	function setupSearch() {
		const searchField = document.getElementById('search-field');
		if (searchField) {
			// Remove old listener by cloning, then add fresh one
			searchField.addEventListener('input', (e) => {
				searchQuery = e.target.value || '';
				currentPage = 1;
				renderPosts();
			});
		}
	}

	function initPosts() {
		const container = document.getElementById('posts-container');
		postsData = JSON.parse(container?.dataset.posts || '[]');
		searchQuery = '';
		currentPage = 1;
		renderPosts();
		setupSearch();
	}

	document.addEventListener('astro:page-load', initPosts);
	initPosts();
</script>

<style>
	.home-container {
		max-width: 800px;
		margin: 0 auto;
		padding: 40px 20px;
	}

	.search-bar {
		width: 100%;
		margin-bottom: 24px;
	}

	.post-grid {
		display: grid;
		gap: 20px;
		margin-bottom: 30px;
	}

	.post-card-wrap {
		border-radius: 12px;
		overflow: hidden;
		cursor: pointer;
	}

	.post-card {
		width: 100%;
		display: block;
	}


	.card-content {
		padding: 20px;
	}

	.card-banner {
		width: 100%;
		height: 160px;
		overflow: hidden;
		border-radius: 12px 12px 0 0;
	}
	.card-banner img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.date {
		color: var(--text-secondary);
		font-size: 0.9em;
	}

	.no-results {
		text-align: center;
		color: var(--text-secondary);
		padding: 40px 0;
	}

	.pagination {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 20px;
	}
</style>
