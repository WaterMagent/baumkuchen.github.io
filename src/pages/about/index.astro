---
import Layout from '../../layouts/Layout.astro';
import { parsePostsFromModules } from '../../lib/utils/posts';
import { renderMarkdown } from '../../lib/utils/markdown';

const mdModules = import.meta.glob('/src/posts/*.md', {
	eager: true,
	query: '?raw',
	import: 'default'
}) as Record<string, string>;

const allModules = parsePostsFromModules(mdModules);
const aboutPage = allModules.find((p) => p.slug === 'about');
---

<Layout currentPath="/about">
	<div class="about-container">
		{aboutPage ? (
			<div class="post-content" id="about-content" set:html={renderMarkdown(aboutPage.content)}>
			</div>
		) : (
			<p style="color: #f44336;">未找到关于页面</p>
		)}
	</div>

	<div class="image-preview-overlay" id="image-overlay" style="display:none">
		<img id="preview-img" src="" alt="Full size preview" />
	</div>
</Layout>

<script>
	// Image preview for about page
	const overlay = document.getElementById('image-overlay');
	const previewImg = document.getElementById('preview-img');

	document.getElementById('about-content')?.addEventListener('click', (e) => {
		const target = e.target;
		if (target.tagName === 'IMG' && overlay && previewImg) {
			previewImg.src = target.src;
			overlay.style.display = 'flex';
		}
	});

	if (overlay) {
		overlay.addEventListener('click', () => {
			overlay.style.display = 'none';
		});
	}
</script>

<style>
	.about-container {
		max-width: 800px;
		margin: 0 auto;
		padding: 32px;
	}

	.post-content {
		line-height: 1.8;
		font-size: 1rem;
	}
</style>
