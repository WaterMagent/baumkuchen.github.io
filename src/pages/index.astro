---
import Layout from '../layouts/Layout.astro';
---

<Layout title="首页">
  <section class="hero">
    <div class="hero-content">
      <div class="hero-avatar-wrapper fade-in stagger-1">
        <div class="hero-avatar-ring">
          <img
            class="hero-avatar"
            src="https://avatars.githubusercontent.com/u/195563565?v=4"
            alt="Baumkuchen"
            width="96"
            height="96"
          />
        </div>
        <span class="hero-status"></span>
      </div>
      <h1 class="hero-title fade-in stagger-2">
        你好，我是 <span class="gradient-text">Baumkuchen</span>
      </h1>
      <p class="hero-subtitle fade-in stagger-3">
        一个热爱写优雅代码、捣鼓酷项目的开发者，
        偶尔也会写点东西记录一下。
      </p>
      <div class="hero-links fade-in stagger-4">
        <a href="/blog" class="btn btn-primary">
          <span class="btn-glow"></span>
          <span class="btn-content">
            阅读博客
          </span>
        </a>
        <a href="/about" class="btn btn-secondary">关于我</a>
      </div>
    </div>
  </section>

  <section class="featured fade-in">
    <h2 class="section-title">
      <span class="section-title-accent"></span>
      最新文章
    </h2>
    <div class="post-list">
      <a href="/hello-world" class="post-card fade-in stagger-1">
        <div class="card-glow"></div>
        <div class="card-banner">
          <img src="https://picsum.photos/seed/hello/240/160" alt="" width="240" height="160" />
        </div>
        <div class="card-body">
          <div class="post-meta">
            <span class="meta-tag">第一篇</span>
          </div>
          <h3 class="post-title">Hello World</h3>
          <p class="post-desc">欢迎来到我的互联网小角落。</p>
          <span class="post-read">
            阅读更多
          </span>
        </div>
      </a>
      <a href="/building-with-astro" class="post-card fade-in stagger-2">
        <div class="card-glow"></div>
        <div class="card-banner">
          <img src="https://picsum.photos/seed/astro/240/160" alt="" width="240" height="160" />
        </div>
        <div class="card-body">
          <div class="post-meta">
            <span class="meta-tag">Astro</span>
          </div>
          <h3 class="post-title">用 Astro 搭建博客</h3>
          <p class="post-desc">为什么 Astro 是我做内容网站的首选框架。</p>
          <span class="post-read">
            阅读更多
          </span>
        </div>
      </a>
    </div>
  </section>
</Layout>

<style is:global>
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 0;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(108, 99, 255, 0.06), transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    text-align: center;
    max-width: 560px;
  }

  .hero-avatar-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .hero-avatar-ring {
    position: relative;
    width: 104px;
    height: 104px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-avatar-ring::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: conic-gradient(var(--accent), var(--accent-cyan), var(--accent-secondary), var(--accent));
    opacity: 0.6;
    animation: hero-ring-spin 4s linear infinite;
  }

  @keyframes hero-ring-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .hero-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid rgba(10, 10, 20, 0.9);
    object-fit: cover;
    position: relative;
    z-index: 1;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .hero-avatar:hover {
    transform: scale(1.05);
    box-shadow: 0 0 40px var(--accent-glow);
  }

  .hero-status {
    position: absolute;
    bottom: 6px;
    right: 6px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #22c55e;
    border: 2px solid var(--bg);
    z-index: 2;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
  }

  .hero-title {
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 0.8rem;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent), var(--accent-cyan), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: hero-gradient-shift 4s ease-in-out infinite;
  }

  @keyframes hero-gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-dim);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none !important;
    position: relative;
    overflow: hidden;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #7b73ff);
    color: #fff !important;
    box-shadow: 0 0 20px var(--accent-glow);
    position: relative;
  }

  .btn-primary:hover {
    box-shadow: 0 0 40px var(--accent-glow), 0 0 60px rgba(108, 99, 255, 0.1);
    transform: translateY(-2px);
  }

  .btn-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    transform: translateX(-100%) skewX(-15deg);
    transition: transform 0.4s;
  }

  .btn-primary:hover .btn-glow {
    transform: translateX(100%) skewX(-15deg);
  }

  .btn-content {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    position: relative;
    z-index: 1;
  }

  .btn-content::after {
    content: '▸';
    font-size: 1.1rem;
    transition: transform 0.2s;
  }

  .btn-primary:hover .btn-content::after {
    transform: translateX(3px);
  }

  .btn-secondary {
    background: rgba(16, 16, 28, 0.6);
    color: var(--text) !important;
    border: 1px solid var(--border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .btn-secondary:hover {
    background: var(--bg-hover);
    border-color: var(--accent);
    box-shadow: 0 0 20px var(--accent-glow);
    transform: translateY(-2px);
  }

  .featured {
    padding: 3rem 0;
    position: relative;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title-accent {
    display: inline-block;
    width: 3px;
    height: 1.2em;
    background: linear-gradient(180deg, var(--accent), var(--accent-cyan));
    border-radius: 2px;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: flex;
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s;
    text-decoration: none !important;
    color: inherit !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .post-card:hover {
    border-color: rgba(108, 99, 255, 0.3);
    transform: translateX(4px);
    background: rgba(18, 18, 34, 0.85);
  }

  .card-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    background: radial-gradient(600px circle at var(--mx, 50%) var(--my, 50%), rgba(108, 99, 255, 0.06), transparent 60%);
  }

  .post-card:hover .card-glow {
    opacity: 1;
  }

  .card-banner {
    width: 200px;
    min-height: 160px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    position: relative;
  }

  .card-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(10, 10, 20, 0.3));
  }

  .card-banner img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .post-card:hover .card-banner img {
    transform: scale(1.05);
  }

  .card-body {
    flex: 1;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-meta {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
  }

  .meta-tag {
    display: inline-block;
    padding: 1px 8px;
    border-radius: 4px;
    background: rgba(108, 99, 255, 0.1);
    border: 1px solid rgba(108, 99, 255, 0.2);
  }

  .post-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 0.3rem;
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }

  .post-read {
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .post-read::after {
    content: '▸';
    font-size: 1.1rem;
    transition: transform 0.2s;
  }

  .post-card:hover .post-read::after {
    transform: translateX(4px);
  }
</style>
