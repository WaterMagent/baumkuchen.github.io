---
import Layout from '../layouts/Layout.astro';
import { parsePostsFromModules } from '../lib/utils/posts';

const mdModules = import.meta.glob('/src/posts/*.md', {
	eager: true,
	query: '?raw',
	import: 'default'
}) as Record<string, string>;

const allModules = parsePostsFromModules(mdModules);
const allPosts = allModules
	.filter((p) => p.type === 'post')
	.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const recentPosts = allPosts.slice(0, 3);
---

<Layout currentPath="/">
	<div class="welcome-container">
		<div class="hero-section">
			<h1>欢迎来到 Baumkuchen 的博客</h1>
			<p>没有要写的</p>
		</div>

		<div class="recent-posts">
			<h2>最近更新</h2>
			<div class="post-list">
				{recentPosts.map((post) => (
					<mdui-card
						variant="outlined"
						class="recent-card"
						onclick={`__nav('/posts/${post.slug}')`}
					>
						{post.banner && (
							<div class="recent-banner">
								<img src={post.banner} alt={post.title} />
							</div>
						)}
						<div class="card-content">
							<h3>{post.title}</h3>
							<p class="date">{post.date}</p>
						</div>
					</mdui-card>
				))}
			</div>

			<div style="margin-top: 20px; text-align: center;">
			<mdui-button variant="text" onclick="__nav('/posts')">查看所有文章 →</mdui-button>
			</div>
		</div>
	</div>
</Layout>

<style>
	.welcome-container {
		max-width: 800px;
		margin: 0 auto;
		padding: 32px;
	}

	.hero-section {
		text-align: center;
		margin-bottom: 48px;
	}

	.recent-posts h2 {
		border-bottom: 2px solid var(--accent);
		display: inline-block;
		padding-bottom: 8px;
		margin-bottom: 24px;
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.recent-card {
		width: 100%;
		display: block;
		cursor: pointer;
		transition: transform 0.2s, border-color 0.2s;
	}

	.recent-card:hover {
		transform: translateX(8px);
		border-color: var(--accent);
	}

	.card-content {
		padding: 16px 24px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.recent-banner {
		width: 100%;
		height: 120px;
		overflow: hidden;
		border-radius: 12px 12px 0 0;
	}
	.recent-banner img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.card-content h3 {
		margin: 0;
		font-size: 1.1em;
	}

	.date {
		color: var(--text-secondary);
		font-size: 0.9em;
		margin: 0;
	}
</style>
