---
import Layout from '../../layouts/Layout.astro';

interface Post {
  url: string;
  frontmatter: {
    title: string;
    date: string;
    description?: string;
    banner?: string;
    listed?: boolean;
  };
}

const postModules = import.meta.glob('../*.md', { eager: true });
const posts: Post[] = Object.entries(postModules)
  .map(([path, mod]) => {
    const url = path.replace(/\.md$/, '/');
    return { url, frontmatter: (mod as any).frontmatter };
  })
  .filter((p) => p.frontmatter.listed !== false);
const sortedPosts = posts.sort(
  (a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Layout title="博客" description="Baumkuchen 的博客文章">
  <section class="blog-page fade-in">
    <h1 class="blog-page-title">
      <span class="page-title-accent"></span>
      博客
    </h1>
    <p class="blog-page-desc">关于代码、技术，以及介于两者之间的一切。</p>

    <div class="blog-list">
      {sortedPosts.map((post, i) => (
        <a href={post.url} class="post-card fade-in" style={`animation-delay: ${i * 0.1}s`}>
          <div class="card-glow"></div>
          {post.frontmatter.banner && (
            <div class="card-banner">
              <img src={post.frontmatter.banner} alt="" width="240" height="160" />
            </div>
          )}
          <div class="card-body">
            <div class="post-meta">
              <span class="meta-tag">
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
            </div>
            <h2 class="post-title">{post.frontmatter.title}</h2>
            <p class="post-desc">{post.frontmatter.description}</p>
            <span class="post-read">
              阅读更多
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style is:global>
  .blog-page {
    padding: 2rem 0;
  }

  .blog-page-title {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .page-title-accent {
    display: inline-block;
    width: 4px;
    height: 1.3em;
    background: linear-gradient(180deg, var(--accent), var(--accent-cyan));
    border-radius: 2px;
  }

  .blog-page-desc {
    color: var(--text-dim);
    margin-bottom: 2.5rem;
    font-size: 1.05rem;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-list .post-card {
    display: flex;
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s;
    text-decoration: none !important;
    color: inherit !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .blog-list .post-card:hover {
    border-color: rgba(108, 99, 255, 0.3);
    background: rgba(18, 18, 34, 0.85);
    transform: translateX(4px);
  }

  .card-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    background: radial-gradient(600px circle at var(--mx, 50%) var(--my, 50%), rgba(108, 99, 255, 0.06), transparent 60%);
  }

  .post-card:hover .card-glow {
    opacity: 1;
  }

  .card-banner {
    width: 200px;
    min-height: 160px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    position: relative;
  }

  .card-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(10, 10, 20, 0.3));
  }

  .card-banner img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .post-card:hover .card-banner img {
    transform: scale(1.05);
  }

  .card-body {
    flex: 1;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .blog-list .post-meta {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
  }

  .meta-tag {
    display: inline-block;
    padding: 1px 8px;
    border-radius: 4px;
    background: rgba(108, 99, 255, 0.1);
    border: 1px solid rgba(108, 99, 255, 0.2);
  }

  .blog-list .post-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 0.3rem;
  }

  .blog-list .post-desc {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }

  .blog-list .post-read {
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .blog-list .post-read::after {
    content: '▸';
    font-size: 1.1rem;
    transition: transform 0.2s;
  }

  .blog-list .post-card:hover .post-read::after {
    transform: translateX(4px);
  }
</style>
