---
import Layout from '../layouts/Layout.astro';
---

<Layout title="留言板" description="用 GitHub 账号留下你的足迹">
  <section class="guestbook fade-in">
    <h1>留言板</h1>
    <p class="guestbook-desc">用 GitHub 账号登录后即可留言，你的足迹会永久留在这里。</p>

    <div id="guestbook-app">
      <div id="message-list" class="message-list">
        <div class="loading">加载留言中...</div>
      </div>

      <div class="guestbook-footer">
        <div id="config-needed" class="setup-guide" style="display:none">
          <p class="setup-title">🔧 需要配置</p>
          <p>在开始前，请创建一个免费的 GitHub OAuth App：</p>
          <ol>
            <li>打开 <a href="https://github.com/settings/developers" target="_blank" rel="noopener">github.com/settings/developers</a></li>
            <li>点击 <strong>New OAuth App</strong></li>
            <li><strong>Application name</strong>：<code>Blog Guestbook</code></li>
            <li><strong>Homepage URL</strong>：<code>https://github.com/baumkuchen/blog</code></li>
            <li><strong>Authorization callback URL</strong>：留空（Device Flow 不需要）</li>
            <li>点击 <strong>Register application</strong></li>
            <li>复制 <strong>Client ID</strong>，粘贴到下面：</li>
          </ol>
          <div class="config-form">
            <input id="client-id-input" class="config-input" type="text" placeholder="粘贴 Client ID 到这里" />
            <button id="save-config-btn" class="btn-primary">保存</button>
          </div>
        </div>

        <div id="auth-section">
          <button id="login-btn" class="btn-github" style="display:none">
            <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            使用 GitHub 登录
          </button>
          <div id="device-flow" class="device-flow" style="display:none">
            <p class="device-instruction">请在 GitHub 中输入以下代码完成验证：</p>
            <div id="device-code" class="device-code"></div>
            <p class="device-hint">
              打开 <a href="https://github.com/login/device" target="_blank" rel="noopener">github.com/login/device</a>
              输入上面的代码，完成后回到此页面。
            </p>
            <button id="check-auth-btn" class="btn-check-auth">已完成验证，检查状态</button>
          </div>
          <div id="user-info" class="user-info" style="display:none">
            <img id="user-avatar" class="user-avatar" alt="" width="36" height="36" />
            <span id="user-name" class="user-name"></span>
            <button id="logout-btn" class="btn-logout">退出</button>
          </div>
        </div>

        <div id="form-section" class="form-section" style="display:none">
          <textarea id="message-input" class="message-input" placeholder="写点什么呢…" maxlength="500" rows="3"></textarea>
          <div class="form-actions">
            <span id="char-count" class="char-count">0/500</span>
            <button id="submit-btn" class="btn-primary">发送留言</button>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
(() => {
  const OWNER = 'baumkuchen';
  const REPO = 'blog';
  const ISSUE_NUM = 1;

  // DOM refs
  const messageListEl = document.getElementById('message-list');
  const configNeeded = document.getElementById('config-needed');
  const clientIdInput = document.getElementById('client-id-input');
  const saveConfigBtn = document.getElementById('save-config-btn');
  const loginBtn = document.getElementById('login-btn');
  const deviceFlowEl = document.getElementById('device-flow');
  const deviceCodeEl = document.getElementById('device-code');
  const userInfoEl = document.getElementById('user-info');
  const userAvatar = document.getElementById('user-avatar');
  const userName = document.getElementById('user-name');
  const logoutBtn = document.getElementById('logout-btn');
  const formSection = document.getElementById('form-section');
  const messageInput = document.getElementById('message-input');
  const charCount = document.getElementById('char-count');
  const submitBtn = document.getElementById('submit-btn');
  const checkAuthBtn = document.getElementById('check-auth-btn');

  let accessToken = localStorage.getItem('gb_token');
  let currentUser = null;
  let currentDeviceCode = null;
  let currentClientId = '';
  let pollTimer = null;

  // --- Load / save client ID ---
  function getClientId() {
    return localStorage.getItem('gb_client_id') || '';
  }

  function showConfigUI() {
    configNeeded.style.display = 'block';
    loginBtn.style.display = 'none';
    const saved = getClientId();
    if (saved) clientIdInput.value = saved;
  }

  function hideConfigUI() {
    configNeeded.style.display = 'none';
    loginBtn.style.display = '';
  }

  saveConfigBtn.addEventListener('click', () => {
    const val = clientIdInput.value.trim();
    if (!val || val.length < 5) {
      alert('请输入有效的 Client ID');
      return;
    }
    localStorage.setItem('gb_client_id', val);
    hideConfigUI();
  });

  // --- Fetch & render messages ---
  async function loadMessages() {
    messageListEl.innerHTML = '<div class="loading">加载留言中...</div>';
    try {
      const res = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/issues/${ISSUE_NUM}/comments?per_page=100`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const comments = await res.json();
      renderMessages(comments);
    } catch {
      messageListEl.innerHTML = '<div class="error-msg">无法加载留言，请稍后再试。</div>';
    }
  }

  function renderMessages(comments) {
    if (!comments.length) {
      messageListEl.innerHTML = '<div class="empty-msg">还没有留言，来写下第一条吧 🎉</div>';
      return;
    }
    comments.reverse();
    messageListEl.innerHTML = comments.map(c => {
      const date = new Date(c.created_at).toLocaleDateString('zh-CN', {
        year: 'numeric', month: 'long', day: 'numeric',
        hour: '2-digit', minute: '2-digit'
      });
      return `
        <div class="message-card">
          <div class="message-header">
            <a href="${c.user.html_url}" target="_blank" rel="noopener" class="message-user">
              <img class="message-avatar" src="${c.user.avatar_url}" alt="${c.user.login}" width="32" height="32" />
              <span class="message-username">${c.user.login}</span>
            </a>
            <span class="message-date">${date}</span>
          </div>
          <div class="message-body">${escapeHtml(c.body)}</div>
        </div>
      `;
    }).join('');
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // --- GitHub OAuth Device Flow ---
  async function startDeviceFlow() {
    const clientId = getClientId();
    if (!clientId) {
      showConfigUI();
      return;
    }

    loginBtn.disabled = true;
    loginBtn.textContent = '请求中...';
    try {
      const res = await fetch('/.netlify/functions/oauth-proxy', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          endpoint: 'device/code',
          client_id: clientId,
          scope: 'public_repo'
        })
      });
      const data = await res.json();
      if (!data.device_code) {
        if (data.error_description) throw new Error(data.error_description);
        throw new Error('请求失败，请检查 Client ID 是否正确');
      }

      deviceCodeEl.textContent = data.user_code;
      loginBtn.style.display = 'none';
      deviceFlowEl.style.display = 'block';
      currentDeviceCode = data.device_code;
      currentClientId = clientId;

      pollAccessToken(data.device_code, data.interval || 5, clientId);
    } catch (err) {
      loginBtn.disabled = false;
      loginBtn.textContent = '使用 GitHub 登录';
      deviceFlowEl.style.display = 'none';
      loginBtn.style.display = '';
      alert(err.message || '登录请求失败，请稍后再试。');
    }
  }

  async function pollAccessToken(deviceCode, interval, clientId) {
    if (pollTimer) clearInterval(pollTimer);
    pollTimer = setInterval(async () => {
      try {
        const res = await fetch('/.netlify/functions/oauth-proxy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            endpoint: 'oauth/access_token',
            client_id: clientId,
            device_code: deviceCode,
            grant_type: 'urn:ietf:params:oauth:grant-type:device_code'
          })
        });
        const data = await res.json();

        if (data.access_token) {
          clearInterval(pollTimer);
          pollTimer = null;
          deviceFlowEl.style.display = 'none';
          accessToken = data.access_token;
          localStorage.setItem('gb_token', accessToken);
          await fetchUser();
        } else if (data.error === 'authorization_pending') {
          // keep polling
        } else if (data.error === 'slow_down') {
          // increase interval naturally
        } else if (data.error === 'expired_token') {
          clearInterval(pollTimer);
          pollTimer = null;
          alert('验证超时，请重新登录。');
          resetAuthUI();
        } else if (data.error === 'access_denied') {
          clearInterval(pollTimer);
          pollTimer = null;
          resetAuthUI();
        }
      } catch {
        clearInterval(pollTimer);
        pollTimer = null;
        resetAuthUI();
      }
    }, interval * 1000);
  }

  // --- Fetch user data ---
  async function fetchUser() {
    if (!accessToken) return;
    try {
      const res = await fetch('https://api.github.com/user', {
        headers: { 'Authorization': `Bearer ${accessToken}` }
      });
      if (!res.ok) throw new Error('Unauthorized');
      currentUser = await res.json();
      showUserUI();
    } catch {
      localStorage.removeItem('gb_token');
      accessToken = null;
      resetAuthUI();
    }
  }

  function showUserUI() {
    loginBtn.style.display = 'none';
    deviceFlowEl.style.display = 'none';
    userInfoEl.style.display = 'flex';
    userAvatar.src = currentUser.avatar_url;
    userAvatar.alt = currentUser.login;
    userName.textContent = currentUser.login;
    formSection.style.display = 'block';
  }

  function resetAuthUI() {
    loginBtn.style.display = getClientId() ? '' : 'none';
    loginBtn.disabled = false;
    loginBtn.textContent = '使用 GitHub 登录';
    deviceFlowEl.style.display = 'none';
    userInfoEl.style.display = 'none';
    formSection.style.display = 'none';
    if (!getClientId()) showConfigUI();
  }

  // --- Submit message ---
  async function submitMessage() {
    const body = messageInput.value.trim();
    if (!body) return;
    submitBtn.disabled = true;
    submitBtn.textContent = '发送中...';

    try {
      const res = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/issues/${ISSUE_NUM}/comments`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${accessToken}`,
          'Accept': 'application/vnd.github.v3+json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ body })
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      messageInput.value = '';
      charCount.textContent = '0/500';
      await loadMessages();
    } catch {
      alert('留言发送失败，请稍后再试。');
    }

    submitBtn.disabled = false;
    submitBtn.textContent = '发送留言';
  }

  // --- Event listeners ---
  loginBtn.addEventListener('click', startDeviceFlow);

  logoutBtn.addEventListener('click', () => {
    localStorage.removeItem('gb_token');
    accessToken = null;
    currentUser = null;
    resetAuthUI();
  });

  checkAuthBtn.addEventListener('click', () => {
    if (currentDeviceCode && currentClientId) {
      pollAccessToken(currentDeviceCode, 5, currentClientId);
    }
  });

  // Auto-check when user returns from GitHub
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden && currentDeviceCode && currentClientId) {
      pollAccessToken(currentDeviceCode, 5, currentClientId);
    }
  });

  messageInput.addEventListener('input', () => {
    const len = messageInput.value.length;
    charCount.textContent = `${len}/500`;
    if (len > 500) messageInput.value = messageInput.value.slice(0, 500);
  });

  submitBtn.addEventListener('click', submitMessage);

  messageInput.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
      e.preventDefault();
      submitMessage();
    }
  });

  // --- Init ---
  loadMessages();

  if (getClientId()) {
    if (accessToken) fetchUser();
    else loginBtn.style.display = '';
  } else {
    showConfigUI();
  }
})();
</script>

<style is:global>
  .guestbook {
    padding: 2rem 0 4rem;
  }

  .guestbook h1 {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
  }

  .guestbook-desc {
    color: var(--text-dim);
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }

  /* Message list */
  .message-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
    min-height: 120px;
  }

  .loading, .empty-msg, .error-msg {
    text-align: center;
    color: var(--text-dim);
    padding: 3rem 1rem;
    font-size: 0.95rem;
  }

  .message-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    transition: border-color 0.2s;
  }

  .message-card:hover {
    border-color: var(--accent);
  }

  .message-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.6rem;
  }

  .message-user {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none !important;
    color: inherit !important;
  }

  .message-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--border);
    object-fit: cover;
  }

  .message-username {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-bright);
  }

  .message-date {
    font-size: 0.75rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .message-body {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text);
    word-break: break-word;
  }

  /* Footer */
  .guestbook-footer {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  /* Setup guide */
  .setup-guide {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem 2rem;
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .setup-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 0.8rem;
  }

  .setup-guide ol {
    padding-left: 1.25rem;
    color: var(--text);
  }

  .setup-guide li {
    margin: 0.4rem 0;
  }

  .setup-guide code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg);
    padding: 1px 6px;
    border-radius: 4px;
  }

  .setup-guide a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .config-form {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .config-input {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.6rem 0.75rem;
    font-size: 0.9rem;
    color: var(--text);
    font-family: var(--font-mono);
  }

  .config-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  /* GitHub login button */
  .btn-github {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.25rem;
    background: #24292e;
    color: #fff !important;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
  }

  .btn-github:hover {
    background: #2b3137;
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .btn-github:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* Device flow */
  .device-flow {
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .device-instruction {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }

  .device-code {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-align: center;
    padding: 0.75rem;
    background: var(--bg);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    user-select: all;
  }

  .device-hint {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .device-hint a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .btn-check-auth {
    display: block;
    width: 100%;
    margin-top: 0.75rem;
    padding: 0.6rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
  }

  .btn-check-auth:hover {
    background: #7b73ff;
    box-shadow: 0 0 20px var(--accent-glow);
  }

  /* User info */
  .user-info {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    object-fit: cover;
  }

  .user-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-bright);
    flex: 1;
  }

  .btn-logout {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
  }

  .btn-logout:hover {
    color: var(--text-bright);
    border-color: var(--accent);
  }

  /* Form */
  .form-section {
    margin-top: 1rem;
  }

  .message-input {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    color: var(--text);
    font-family: var(--font-sans);
    resize: vertical;
    min-height: 80px;
    transition: border-color 0.2s;
    line-height: 1.5;
  }

  .message-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .message-input::placeholder {
    color: var(--text-dim);
  }

  .form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.6rem;
  }

  .char-count {
    font-size: 0.8rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.25rem;
    background: var(--accent);
    color: #fff !important;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
  }

  .btn-primary:hover {
    background: #7b73ff;
    box-shadow: 0 0 20px var(--accent-glow);
    transform: translateY(-1px);
  }

  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }
</style>
