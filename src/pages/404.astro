---
import Layout from '../layouts/Layout.astro';
---

<Layout currentPath="">
	<div class="not-found">
		<h1>404</h1>
		<p>页面未找到</p>
		<mdui-button variant="text" onclick="__nav('/')">返回主页</mdui-button>
	</div>
</Layout>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 60vh;
		gap: 16px;
		text-align: center;
		padding: 32px;
	}
	.not-found h1 {
		font-size: 4rem;
		margin: 0;
		color: var(--accent);
		font-weight: 700;
	}
	.not-found p {
		font-size: 1.1rem;
		color: var(--text-secondary);
		margin: 0;
	}
</style>
