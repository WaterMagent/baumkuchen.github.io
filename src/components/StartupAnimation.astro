---
// Startup animation — plays once on page load, then dismisses
// State is persisted in sessionStorage so it only plays once per tab session
---

<style is:global>
  #startup-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #050508;
    transition: opacity 0.8s ease, transform 0.8s ease;
    pointer-events: none;
  }

  #startup-overlay.dismissed {
    opacity: 0;
    transform: scale(1.08);
    filter: blur(4px);
  }

  #startup-overlay.hidden {
    display: none;
  }

  /* ═══════════════════════════════════════
     HEX GRID BACKGROUND
     ═══════════════════════════════════════ */
  .startup-hex-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.12;
    background:
      /* vertical lines */
      repeating-linear-gradient(90deg,
        transparent,
        transparent 51px,
        rgba(0, 240, 255, 0.08) 51px,
        rgba(0, 240, 255, 0.08) 52px
      ),
      /* horizontal lines offset by half for hex effect */
      repeating-linear-gradient(0deg,
        transparent,
        transparent 29px,
        rgba(0, 240, 255, 0.08) 29px,
        rgba(0, 240, 255, 0.08) 30px
      ),
      /* diagonal / */
      repeating-linear-gradient(60deg,
        transparent,
        transparent 58px,
        rgba(108, 99, 255, 0.06) 58px,
        rgba(108, 99, 255, 0.06) 59px
      );
    mask-image: radial-gradient(ellipse 70% 50% at 50% 50%, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 50%, black 30%, transparent 70%);
    animation: hex-pulse 4s ease-in-out infinite;
  }

  @keyframes hex-pulse {
    0%, 100% { opacity: 0.08; }
    50% { opacity: 0.18; }
  }

  /* ═══════════════════════════════════════
     CANVAS — DIGITAL RAIN
     ═══════════════════════════════════════ */
  #startup-rain {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    opacity: 0.15;
    pointer-events: none;
  }

  /* ═══════════════════════════════════════
     SCANLINE SWEEP
     ═══════════════════════════════════════ */
  .startup-sweep {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 40%,
      rgba(0, 240, 255, 0.03) 45%,
      rgba(108, 99, 255, 0.04) 48%,
      rgba(0, 240, 255, 0.03) 52%,
      transparent 55%,
      transparent 100%
    );
    background-size: 100% 200%;
    animation: sweep-down 4s ease-in-out infinite;
  }

  @keyframes sweep-down {
    0% { background-position: 0 0; }
    100% { background-position: 0 100%; }
  }

  /* ═══════════════════════════════════════
     HEXAGONAL RINGS
     ═══════════════════════════════════════ */
  .startup-hex-ring {
    position: absolute;
    z-index: 3;
    border: 1px solid rgba(108, 99, 255, 0.12);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    animation: hex-rotate 8s linear infinite;
    opacity: 0.3;
  }

  .startup-hex-ring:nth-child(3) {
    width: 260px;
    height: 300px;
  }

  .startup-hex-ring:nth-child(4) {
    width: 360px;
    height: 415px;
    animation-direction: reverse;
    animation-duration: 10s;
    border-color: rgba(0, 240, 255, 0.08);
  }

  .startup-hex-ring:nth-child(5) {
    width: 460px;
    height: 530px;
    animation-duration: 12s;
    border-color: rgba(255, 107, 157, 0.06);
  }

  @keyframes hex-rotate {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.05); }
    100% { transform: rotate(360deg) scale(1); }
  }

  /* ═══════════════════════════════════════
     CORNER BRACKETS [code-style]
     ═══════════════════════════════════════ */
  .startup-brackets {
    position: absolute;
    inset: 30px;
    z-index: 4;
    pointer-events: none;
  }

  .startup-bracket {
    position: absolute;
    color: rgba(108, 99, 255, 0.2);
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 200;
    letter-spacing: -2px;
  }

  .startup-bracket-tl { top: 0; left: 0; }
  .startup-bracket-tr { top: 0; right: 0; }
  .startup-bracket-bl { bottom: 0; left: 0; }
  .startup-bracket-br { bottom: 0; right: 0; transform: scaleX(-1); }

  /* Binary bits floating along edges */
  .startup-bits {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    overflow: hidden;
  }

  .startup-bit {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: rgba(0, 240, 255, 0.15);
    animation: bit-scroll 8s linear infinite;
  }

  @keyframes bit-scroll {
    0% { transform: translateY(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-120px); opacity: 0; }
  }

  /* ═══════════════════════════════════════
     CENTER CONTENT
     ═══════════════════════════════════════ */
  .startup-content {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  /* ── Avatar with holographic ring ── */
  .startup-avatar-wrap {
    position: relative;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.25rem;
  }

  .startup-avatar-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    padding: 2px;
    background: conic-gradient(
      var(--accent),
      var(--accent-cyan),
      transparent 40%,
      transparent 60%,
      var(--accent-cyan),
      var(--accent-secondary),
      var(--accent)
    );
    animation: avatar-ring-spin 2s linear infinite;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
  }

  @keyframes avatar-ring-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .startup-avatar-ring-pulse {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(0, 240, 255, 0.08);
    animation: ring-pulse 2s ease-out infinite;
  }

  @keyframes ring-pulse {
    0% { transform: scale(1); opacity: 0.4; }
    100% { transform: scale(1.3); opacity: 0; }
  }

  .startup-logo {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid rgba(10, 10, 20, 0.9);
    object-fit: cover;
    position: relative;
    z-index: 1;
    opacity: 0;
    animation: logoAppear 0.6s ease-out 0.1s forwards;
  }

  @keyframes logoAppear {
    from { opacity: 0; transform: scale(0.3) rotate(-30deg); filter: brightness(2) hue-rotate(60deg); }
    to { opacity: 1; transform: scale(1) rotate(0deg); filter: none; }
  }

  /* ── Name with glitch ── */
  .startup-name {
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    font-family: var(--font-sans);
    position: relative;
    opacity: 0;
    animation: nameReveal 0.7s ease-out 0.4s forwards;
  }

  .startup-name-text {
    background: linear-gradient(135deg, var(--accent), var(--accent-cyan), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: gradient-shift 3s ease-in-out 0.4s infinite;
    position: relative;
    z-index: 1;
  }

  .startup-name-glitch {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.1;
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--accent-cyan);
    animation: glitch-offset 0.3s ease-in-out 0.4s infinite;
    pointer-events: none;
    user-select: none;
  }

  .startup-name-glitch::before {
    content: 'Baumkuchen';
    position: absolute;
    left: -2px;
    color: #ff0040;
    clip-path: inset(20% 0 50% 0);
  }

  .startup-name-glitch::after {
    content: 'Baumkuchen';
    position: absolute;
    left: 2px;
    color: #00f0ff;
    clip-path: inset(60% 0 10% 0);
  }

  @keyframes glitch-offset {
    0%, 90%, 100% { transform: translate(0); }
    92% { transform: translate(-3px, 1px); }
    94% { transform: translate(3px, -1px); }
    96% { transform: translate(-1px, 2px); }
    98% { transform: translate(2px, -2px); }
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @keyframes nameReveal {
    from { opacity: 0; transform: translateY(12px) scale(0.95); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0) scale(1); filter: none; }
  }

  /* ── Boot terminal output ── */
  .startup-terminal {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    line-height: 1.6;
    text-align: left;
    width: 260px;
    margin-top: 0.4rem;
    min-height: 3.2em;
    opacity: 0;
    animation: fadeIn 0.3s ease-out 0.7s forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .startup-terminal-line {
    opacity: 0;
    animation: terminal-type 0.01s linear forwards;
    white-space: nowrap;
    overflow: hidden;
  }

  .startup-terminal-prompt {
    color: var(--accent-cyan);
  }

  .startup-terminal-cmd {
    color: var(--text-dim);
  }

  .startup-terminal-ok {
    color: #22c55e;
  }

  .startup-terminal-info {
    color: var(--accent);
  }

  .startup-terminal-cursor {
    display: inline-block;
    width: 0.55em;
    height: 1em;
    background: var(--accent-cyan);
    vertical-align: text-bottom;
    margin-left: 2px;
    animation: terminal-cursor 0.6s step-end infinite;
  }

  @keyframes terminal-cursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ── Loading bar ── */
  .startup-bar {
    position: relative;
    z-index: 1;
    margin-top: 1rem;
    width: 200px;
    height: 3px;
    background: rgba(108, 99, 255, 0.08);
    border-radius: 3px;
    overflow: hidden;
    opacity: 0;
    animation: fadeIn 0.3s ease-out 1.6s forwards;
  }

  .startup-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent), var(--accent-cyan), var(--accent-secondary), var(--accent));
    background-size: 300% 100%;
    border-radius: 3px;
    animation: barFill 1s ease-in-out 1.7s forwards, bar-shimmer 0.6s linear 1.7s infinite;
    box-shadow: 0 0 8px rgba(0, 240, 255, 0.3);
  }

  @keyframes barFill {
    0% { width: 0%; }
    40% { width: 60%; }
    80% { width: 85%; }
    100% { width: 100%; }
  }

  @keyframes bar-shimmer {
    0% { background-position: 300% 0; }
    100% { background-position: -300% 0; }
  }

  /* ── Glitch dismiss ── */
  @keyframes glitch-dismiss {
    0% { opacity: 1; transform: none; filter: none; }
    5% { opacity: 1; transform: translate(-4px, 2px); filter: hue-rotate(90deg) brightness(1.5); }
    10% { opacity: 1; transform: translate(4px, -2px); filter: hue-rotate(-90deg) brightness(1.2); }
    15% { opacity: 1; transform: translate(-2px, 1px); filter: none; }
    20% { opacity: 0.95; transform: none; filter: saturate(2); }
    30% { opacity: 0.8; transform: scale(1.02); filter: brightness(0.5); }
    50% { opacity: 0.4; transform: scale(0.98); filter: blur(2px); }
    100% { opacity: 0; transform: scale(1.1); filter: blur(6px); }
  }

  .startup-glitch-layer {
    position: absolute;
    inset: 0;
    z-index: 6;
    pointer-events: none;
    opacity: 0;
    background: rgba(255, 0, 64, 0.02);
  }

  #startup-overlay.dismissed .startup-glitch-layer {
    opacity: 1;
    animation: glitch-dismiss 1s ease-out forwards;
  }

  #startup-overlay.dismissed .startup-glitch-layer::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(255, 255, 255, 0.02) 3px,
      transparent 4px
    );
    animation: glitch-scanlines 0.1s linear 5;
  }

  @keyframes glitch-scanlines {
    0% { transform: translateY(0); }
    100% { transform: translateY(4px); }
  }
</style>

<div id="startup-overlay">
  <div class="startup-hex-grid"></div>
  <canvas id="startup-rain"></canvas>
  <div class="startup-sweep"></div>
  <div class="startup-hex-ring"></div>
  <div class="startup-hex-ring"></div>
  <div class="startup-hex-ring"></div>
  <div class="startup-brackets">
    <span class="startup-bracket startup-bracket-tl">[===</span>
    <span class="startup-bracket startup-bracket-tr">===]</span>
    <span class="startup-bracket startup-bracket-bl">[===</span>
    <span class="startup-bracket startup-bracket-br">===]</span>
  </div>
  <div class="startup-bits" id="startup-bits"></div>
  <div class="startup-glitch-layer"></div>
  <div class="startup-content">
    <div class="startup-avatar-wrap">
      <div class="startup-avatar-ring"></div>
      <div class="startup-avatar-ring-pulse"></div>
      <img
        class="startup-logo"
        src="https://avatars.githubusercontent.com/u/195563565?v=4"
        alt="Baumkuchen"
        width="64"
        height="64"
      />
    </div>
    <div class="startup-name">
      <span class="startup-name-text">Baumkuchen</span>
      <div class="startup-name-glitch" aria-hidden="true"></div>
    </div>
    <div class="startup-terminal" id="startup-terminal">
      <div class="startup-terminal-line">
        <span class="startup-terminal-prompt">$</span>
        <span class="startup-terminal-cmd"> sv status blog</span>
      </div>
      <div class="startup-terminal-line">
        <span class="startup-terminal-ok">  ✓</span>
        <span class="startup-terminal-info"> blog: up</span>
        <span class="startup-terminal-cmd"> (pid 2304) 1842s</span>
      </div>
      <div class="startup-terminal-line">
        <span class="startup-terminal-ok">  ✓</span>
        <span class="startup-terminal-info"> blog: running</span>
        <span class="startup-terminal-cmd"> — Baumkuchen Blog Engine</span>
      </div>
      <div class="startup-terminal-line">
        <span class="startup-terminal-prompt">$</span>
        <span class="startup-terminal-cmd"> </span>
        <span class="startup-terminal-cursor"></span>
      </div>
    </div>
    <div class="startup-bar">
      <div class="startup-bar-fill"></div>
    </div>
  </div>
</div>

<script>
  (() => {
    const overlay = document.getElementById('startup-overlay');
    if (!overlay) return;

    // Only play once per tab session
    if (sessionStorage.getItem('startupShown')) {
      overlay.classList.add('hidden');
      return;
    }

    sessionStorage.setItem('startupShown', 'true');
    overlay.style.pointerEvents = 'auto';

    /* ── Digital Rain (Canvas) ── */
    const canvas = document.getElementById('startup-rain');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let w = canvas.width = window.innerWidth;
      let h = canvas.height = window.innerHeight;

      const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789<>/{}[]|&';
      const cols = Math.floor(w / 14);
      const drops = Array.from({ length: cols }, () => ({ y: Math.random() * -h, speed: 0.3 + Math.random() * 0.5 }));

      function drawRain() {
        ctx.fillStyle = 'rgba(5, 5, 8, 0.08)';
        ctx.fillRect(0, 0, w, h);

        ctx.font = '11px monospace';
        for (let i = 0; i < drops.length; i++) {
          const char = chars[Math.floor(Math.random() * chars.length)];
          const x = i * 14;
          const y = drops[i].y;

          ctx.fillStyle = `rgba(0, 240, 255, ${0.02 + Math.random() * 0.04})`;
          ctx.fillText(char, x, y);

          drops[i].y += drops[i].speed;
          if (y > h) {
            drops[i].y = Math.random() * -100 - 20;
            drops[i].speed = 0.3 + Math.random() * 0.5;
          }
        }
      }

      let rainInterval = setInterval(drawRain, 60);
      const resizeHandler = () => {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      };
      window.addEventListener('resize', resizeHandler);

      // Clean up rain on dismiss
      const origDismiss = () => {
        clearInterval(rainInterval);
        window.removeEventListener('resize', resizeHandler);
      };
      // Hook into dismiss by overriding the setTimeout
      const _origSetTimeout = window.setTimeout;
      // We'll just let it be - the canvas will be hidden with the overlay
    }

    /* ── Binary bits along edges ── */
    const bitsContainer = document.getElementById('startup-bits');
    if (bitsContainer) {
      const bitChars = '01';
      const bitCount = 24;
      for (let i = 0; i < bitCount; i++) {
        const bit = document.createElement('span');
        bit.className = 'startup-bit';
        bit.textContent = bitChars[Math.floor(Math.random() * 2)];
        const isLeft = i < bitCount / 2;
        const pos = (i % (bitCount / 2)) / (bitCount / 2 - 1);
        bit.style.cssText = `
          ${isLeft ? 'left' : 'right'}: 4px;
          bottom: ${20 + pos * 60}%;
          animation-delay: ${Math.random() * 4}s;
          animation-duration: ${4 + Math.random() * 4}s;
        `;
        bitsContainer.appendChild(bit);
      }
    }

    /* ── Terminal typewriter effect ── */
    const lines = document.querySelectorAll('.startup-terminal-line');
    lines.forEach((line, idx) => {
      line.style.animationDelay = `${0.8 + idx * 0.15}s`;
      line.style.setProperty('--chars', line.textContent?.length || 1);
      // Use a simpler reveal: fade + translate
      line.style.animation = 'none';
      line.style.opacity = '0';
      setTimeout(() => {
        line.style.transition = 'opacity 0.15s ease-out';
        line.style.opacity = '1';
      }, 800 + idx * 150);
    });

    /* ── Dismiss after animation completes ── */
    setTimeout(() => {
      overlay.classList.add('dismissed');
      setTimeout(() => {
        overlay.classList.add('hidden');
      }, 1000);
    }, 2800);
  })();
</script>
